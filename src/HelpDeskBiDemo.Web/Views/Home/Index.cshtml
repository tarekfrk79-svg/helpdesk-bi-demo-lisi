@model HelpDeskBiDemo.Web.ViewModels.HomeAccessViewModel
@{
    ViewData["Title"] = "Accueil";
}

<section class="landing-shell">
    <div class="container py-5">
        <div class="row g-4 align-items-stretch">
            <div class="col-lg-7">
                <div class="hero-panel h-100">
                    <span class="eyebrow">Recruiter-ready ASP.NET Core demo</span>
                    <h1 class="display-5 fw-bold mb-3">HelpDesk BI Demo</h1>
                    <p class="lead mb-4">
                        Une application de support utilisateurs en C# / ASP.NET Core / .NET 8
                        concue pour montrer concretement mes competences en developpement web,
                        SQL Server, support utilisateurs et BI.
                    </p>

                    <div class="badge-cloud mb-4">
                        <span class="tech-badge">C#</span>
                        <span class="tech-badge">ASP.NET Core MVC</span>
                        <span class="tech-badge">.NET 8</span>
                        <span class="tech-badge">SQL Server</span>
                        <span class="tech-badge">Entity Framework Core</span>
                        <span class="tech-badge">Bootstrap</span>
                        <span class="tech-badge">Tableau Software</span>
                        <span class="tech-badge">Azure App Service</span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="info-card">
                                <h2 class="h5">Competences demontrees</h2>
                                <p>
                                    Developpement web Microsoft, modelisation de donnees, logique
                                    support, export BI et deploiement cloud.
                                </p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-card">
                                <h2 class="h5">Vision produit</h2>
                                <p>
                                    Un seul point d'entree, un espace Owner prive, puis une demo
                                    entreprise simple a explorer selon plusieurs roles.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="access-panel h-100">
                    <h2 class="h3 mb-3">Entrer dans la demo</h2>
                    <p class="text-secondary mb-4">
                        Un seul champ accepte soit ton code Owner, soit le code entreprise partage a un recruteur.
                    </p>

                    <form asp-action="EnterCode" method="post">
                        @Html.AntiForgeryToken()
                        <label class="form-label fw-semibold" for="access-code">Code d'acces</label>
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                        <input
                            id="access-code"
                            asp-for="AccessCode"
                            class="form-control form-control-lg mb-3"
                            type="text"
                            placeholder="OWNER-DEMO-2026 ou SOPRA-8K42" />
                        <button class="btn btn-brand btn-lg w-100" type="submit">
                            Entrer
                        </button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
