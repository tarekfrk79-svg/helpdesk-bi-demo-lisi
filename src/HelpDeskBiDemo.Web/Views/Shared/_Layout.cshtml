@inject HelpDeskBiDemo.Application.Abstractions.INotificationService NotificationService
@{
    var companyName = Context.Session.GetCompanyName();
    var activeRole = Context.Session.GetRole();
    var activePerson = Context.Session.GetPersonDisplayName();
    var isOwnerAuthorized = Context.Session.IsOwnerAuthorized();
    var flashMessage = TempData["FlashMessage"] as string;
    var notificationSummary = (!string.IsNullOrWhiteSpace(companyName) && activeRole.HasValue)
        ? await NotificationService.GetHeaderSummaryAsync(
            Context.Session.GetCompanyId()!.Value,
            activeRole.Value,
            Context.Session.GetPersonId())
        : null;
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HelpDesk BI Demo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="navbar navbar-expand-lg py-3">
            <div class="container">
                <div class="d-flex flex-column flex-lg-row align-items-lg-center gap-2">
                    <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">HelpDesk BI Demo</a>
                    @if (isOwnerAuthorized)
                    {
                        <span class="header-badge">Mode Owner</span>
                    }
                    else if (!string.IsNullOrWhiteSpace(companyName))
                    {
                        <span class="header-badge">@companyName</span>
                    }
                </div>

                <div class="d-flex flex-wrap align-items-center justify-content-end gap-2">
                    @if (activeRole.HasValue)
                    {
                        <span class="header-badge">@activeRole.Value.ToDisplayLabel()</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(activePerson))
                    {
                        <span class="header-badge">@activePerson</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(companyName))
                    {
                        <a class="btn btn-outline-dark btn-sm" asp-controller="Demo" asp-action="RoleSelection">Choix du role</a>
                        <a class="btn btn-outline-dark btn-sm" asp-controller="Demo" asp-action="Dashboard">Dashboard demo</a>
                        <a class="btn btn-outline-dark btn-sm" asp-controller="Tickets" asp-action="Index">Tickets</a>
                        <a class="btn btn-outline-dark btn-sm position-relative" asp-controller="Notifications" asp-action="Index">
                            Notifications
                            @if (notificationSummary is not null && notificationSummary.AttentionCount > 0)
                            {
                                <span class="header-notification-count">@notificationSummary.AttentionCount</span>
                            }
                        </a>
                        <form asp-controller="Demo" asp-action="ExitCompany" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-outline-dark btn-sm" type="submit">Quitter la demo</button>
                        </form>
                    }
                    @if (isOwnerAuthorized)
                    {
                        <a class="btn btn-outline-dark btn-sm" asp-controller="Owner" asp-action="Index">Espace Owner</a>
                        <form asp-controller="Owner" asp-action="Exit" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-outline-dark btn-sm" type="submit">Quitter Owner</button>
                        </form>
                    }
                    <a class="btn btn-light btn-sm border" asp-controller="Home" asp-action="Index">Accueil</a>
                </div>
            </div>
        </nav>
    </header>

    <main>
        @if (!string.IsNullOrWhiteSpace(flashMessage))
        {
            <div class="container pt-3">
                <div class="alert alert-info shadow-sm border-0 rounded-4 mb-0">@flashMessage</div>
            </div>
        }
        @RenderBody()
    </main>

    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
