@model HelpDeskBiDemo.Web.Models.ErrorViewModel
@{
    ViewData["Title"] = "Erreur";
}

<section class="container py-5">
    <div class="info-card">
        <h1 class="h3 mb-3">Une erreur s'est produite.</h1>
        <p class="mb-0">La demo a rencontre un probleme inattendu.</p>
        @if (Model.ShowRequestId)
        {
            <p class="mt-3 mb-0"><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
        }
    </div>
</section>
